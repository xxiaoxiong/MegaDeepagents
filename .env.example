# ===== 基础 =====
APP_NAME=general-agent-framework
APP_ENV=dev

# ===== 模型配置 =====
LLM_PROVIDER=openai-compatible
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=

# ===== 路径 =====
RUNTIME_DIR=./runtime
WORKSPACE_DIR=./runtime/workspace
MEMORY_FILE=./runtime/memory/MEMORY.md
USER_FILE=./runtime/memory/USER.md
SKILLS_DIR=./runtime/skills
SQLITE_PATH=./runtime/db/app.sqlite3

# ===== 功能开关 =====
ENABLE_WEB_TOOLS=false
ENABLE_SAFE_SHELL=false
ENABLE_MCP_TOOLS=false

# ===== Safety =====
HITL_REQUIRED_FOR_WRITE=true
HITL_REQUIRED_FOR_SKILL_CHANGE=true
HITL_REQUIRED_FOR_MEMORY_CHANGE=true

# ===== 子智能体系统 =====
ENABLE_SUBAGENTS=true
ENABLE_ASYNC_SUBAGENTS=false
ASYNC_SUBAGENT_URL=http://127.0.0.1:2024

# ===== 沙箱隔离 =====
SANDBOX_PROVIDER=none  # none | local | daytona | modal
SANDBOX_ROOT_DIR=./runtime/sandbox
SANDBOX_TIMEOUT=60

# ===== 事件流式输出 =====
ENABLE_STREAMING=false
STREAM_HEARTBEAT_INTERVAL=15

# ===== 跨线程持久化 =====
ENABLE_CROSS_THREAD_MEMORY=false
CROSS_THREAD_MEMORY_PATH=./runtime/store.db

# ===== 响应格式结构化 =====
ENABLE_RESPONSE_FORMAT=false

# ===== LLM 缓存 =====
ENABLE_LLM_CACHE=true
LLM_CACHE_PATH=./runtime/cache/llm_cache.db

# ===== 辅助 / 反思模型（非主链路，留空则回退主模型）=====
# AUX_LLM_PROVIDER=openai-compatible
# AUX_LLM_MODEL=deepseek-chat
# AUX_LLM_API_KEY=
# AUX_LLM_BASE_URL=
# REFLECTION_LLM_PROVIDER=openai-compatible
# REFLECTION_LLM_MODEL=deepseek-chat
# REFLECTION_LLM_API_KEY=
# REFLECTION_LLM_BASE_URL=

# ===== LangSmith 可观测性（可选，默认关闭）=====
LANGSMITH_ENABLED=true
LANGSMITH_API_KEY=      # 填入你的 LangSmith API Key
LANGSMITH_PROJECT=megaDeepagents
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_SERVICE_NAME=megaDeepagents
LANGSMITH_SAMPLE_RATE=1.0
LANGSMITH_OFFLINE_LOG=true
